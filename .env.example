# ═══════════════════════════════════════════
# Crypto Alpha - Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git!
# ═══════════════════════════════════════════

# --- Binance API ---
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crypto_alpha
DB_USER=root
DB_PASSWORD=your_db_password_here

# Option 2: Full connection string (overrides above if set)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/crypto_alpha?charset=utf8mb4

# --- Telegram Alerts (Phase 5, optional for now) ---
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
