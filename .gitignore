# ═══════════════════════════════════════════
# Crypto Alpha - Git Ignore
# ═══════════════════════════════════════════

# --- Secrets (CRITICAL - never commit) ---
.env
*.key
*.pem

# --- Python ---
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_metadata/

# --- Logs ---
logs/*.log

# --- Data (large files) ---
data/*.csv
data/*.parquet
data/*.db
data/*.sqlite

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
